#!/bin/bash
if pgrep  "prl_client_app" >/dev/null
then
   echo "Cannot continue since Parallels is running."
   exit 1
fi

if pgrep  "VMware Fusion" >/dev/null
then
   echo "Cannot continue since VMware Fusion is running."
   exit 1
fi

HOSTNAME=`hostname`

if [ "$HOSTNAME" == "m4.lan" ]; then
   TARGETS="FAST1 FAST3"
elif [ "$HOSTNAME" == "main.lan" ]; then
   TARGETS="FAST2 FAST4"
else
   echo "Unknown hostname. Exiting."
   exit 1
fi

for TARGET in $TARGETS; do
   echo "Backing up to $TARGET"
   DEST="/Volumes/$TARGET/$HOSTNAME"
   mkdir -p "$DEST"
   rsync -Partv ~/vmware-vms "$DEST"
done

